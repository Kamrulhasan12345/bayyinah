<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<VBox xmlns="http://javafx.com/javafx/null" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ks.bayyinah.controller.RegistrationController" styleClass="auth-modal-root" stylesheets="@../css/stylesheet.css">
   <children>
   <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="450.0" spacing="40.0" styleClass="auth-modal-card">
         <children>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Bayyinah" textAlignment="CENTER" />
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Register" textAlignment="CENTER" />
            <VBox alignment="CENTER" spacing="20.0">
               <children>
                  <TextField fx:id="usernameField" promptText="Username">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </TextField>
                  <TextField fx:id="emailField" promptText="Email" />
                  <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="20.0">
                     <children>
                        <TextField fx:id="firstNameField" maxWidth="1.7976931348623157E308" promptText="First Name" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="lastNameField" maxWidth="1.7976931348623157E308" promptText="Last Name" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <PasswordField fx:id="passwordField" promptText="Password" />
                  <Button fx:id="registerBtn" alignment="CENTER" contentDisplay="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#register" text="Register" textAlignment="CENTER" />
               </children>
            </VBox>
            <HBox>
               <children>
                  <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Already a user?" HBox.hgrow="ALWAYS" />
                  <Hyperlink fx:id="loginRedirect" alignment="CENTER" maxWidth="1.7976931348623157E308" onAction="#goToLogin" text="Login" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</VBox>
